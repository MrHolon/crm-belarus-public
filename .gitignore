Desktop.ini
$RECYCLE.BIN/

# ===================================================================
# Cursor AI
# ===================================================================
# Commit mcp.json so the whole team gets the same MCP setup, but keep
# everything else in .cursor/ local.
.cursor/*
!.cursor/mcp.json

# ===================================================================
# Agent skills CLI (https://www.npmjs.com/package/skills)
# -------------------------------------------------------------------
# Source of truth (actual files) lives in .agents/skills/.
# The .<agent>/ folders and skills/<package>/ below them are just
# Windows junctions/symlinks to .agents/skills/*; they are regenerated
# on any machine via `npx skills experimental_sync` and MUST stay out
# of git (Windows junctions break checkouts on Linux/macOS).
# ===================================================================
.adal/
.augment/
.bob/
.claude/
.codebuddy/
.commandcode/
.continue/
.cortex/
.crush/
.factory/
.goose/
.iflow/
.junie/
.kilocode/
.kiro/
.kode/
.mcpjam/
.mux/
.neovate/
.openhands/
.pi/
.pochi/
.qoder/
.qwen/
.roo/
.trae/
.vibe/
.windsurf/
.zencoder/

# Junctions into .agents/skills/ that the CLI creates alongside our own
# hand-written markdown docs in skills/.
skills/supabase/
skills/supabase-postgres-best-practices/

