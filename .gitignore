# ===================================================================
# Environment & secrets
# ===================================================================
.env
.env.local
.env.*.local
.env.old
*.pem
*.key

# -------------------------------------------------------------------
# Deliberate opt-in for this public demo repo:
# Commit root .env, supabase/.env, local-test-accounts.md and the
# latest pg_dump so `docker compose up` works out of the box.
# All values are local-dev defaults (Supabase demo keys, etc.).
# DO NOT copy this setup to any deployment reachable from the Internet.
# -------------------------------------------------------------------
!/.env
!/supabase/.env
!/local-test-accounts.md

# Локальные логины/пароли для входа (см. local-test-accounts.example.md)
local-test-accounts.md

# ===================================================================
# Supabase self-hosted — persistent data and runtime artifacts
# -------------------------------------------------------------------
# Config files under volumes/ (kong.yml, vector.yml, init SQL, pooler
# config, edge-function sources) MUST be tracked — they are mounted
# into containers and any change to them needs to be reviewed. Only
# runtime data directories should be ignored.
# ===================================================================
supabase/volumes/db/data/
supabase/volumes/storage/
supabase/.branches/
supabase/.temp/

# ===================================================================
# Local backups (pg_dump output)
# ===================================================================
backups/
*.sql.gz
*.dump

# Opt-in: commit the bundled initial dump so the repo restores out of
# the box. Future dumps placed next to it stay ignored.
!/backups/
!/backups/README.md
!/backups/supabase-postgres-20260418-122604.dump

# ===================================================================
