# ===================================================================
# CRM Belarus — root .env template (UI / crm-belarus container)
#
# Copy to .env and fill in real values. NEVER commit .env.
#
# The Supabase self-hosted stack uses its own env file:
#   ./supabase/.env
# which is generated automatically by supabase/utils/generate-keys.sh
# and supabase/utils/add-new-auth-keys.sh.
# ===================================================================

# -------------------------------------------------------------------
# UI (Vite) — consumed by the crm-belarus container
# -------------------------------------------------------------------
# Public Kong gateway. Must match KONG_HTTP_PORT in supabase/.env.
VITE_SUPABASE_URL=http://localhost:8000

# Copy ANON_KEY from supabase/.env (not the service_role key!).
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJhbm9uIiwKICAgICJpc3MiOiAic3VwYWJhc2UtZGVtbyIsCiAgICAiaWF0IjogMTY0MTc2OTIwMCwKICAgICJleHAiOiAxNzk5NTM1NjAwCn0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE

# -------------------------------------------------------------------
# Role-based tests (`npm run test:roles`, `npm run e2e`) — local only
# -------------------------------------------------------------------
# Service role key for cleanup fixtures. Copy SERVICE_ROLE_KEY from
# supabase/.env. NEVER expose this to the browser — it bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJzZXJ2aWNlX3JvbGUiLAogICAgImlzcyI6ICJzdXBhYmFzZS1kZW1vIiwKICAgICJpYXQiOiAxNjQxNzY5MjAwLAogICAgImV4cCI6IDE3OTk1MzU2MDAKfQ.DaYlNEoUrrEn2Ig7tqibS-PHK5vgusbcbo7X36XVt4Q

# Shared password for the 6 local test accounts (see
# local-test-accounts.md). Tests default to this value if unset.
TEST_USER_PASSWORD=LocalCRM_Dev_2026!

# -------------------------------------------------------------------
# Ports summary (for reference; actual values live in supabase/.env)
# -------------------------------------------------------------------
# Kong HTTP (Supabase API + Studio UI): http://localhost:8000
# Postgres (via Supavisor pooler):      localhost:5432
# Pooler transaction mode:              localhost:6543
# UI (crm-belarus container):          http://localhost:8080
